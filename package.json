{
  "name": "vibe-machine",
  "version": "1.0.0",
  "description": "A real-time, audio-reactive music visualizer with 10 visualization modes, 640 possible combinations, and zero runtime dependencies. Pure vibes.",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js 3000",
    "electron": "electron .",
    "build": "electron-builder",
    "test": "node node_modules/jest/bin/jest.js",
    "test:watch": "node node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node node_modules/jest/bin/jest.js --coverage"
  },
  "keywords": [
    "audio",
    "visualizer",
    "web-audio-api",
    "canvas",
    "music",
    "real-time",
    "vanilla-js"
  ],
  "author": "Jeremy Brachle",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.vibemachine.app",
    "productName": "Vibe Machine",
    "files": [
      "electron-main.js",
      "server.js",
      "public/**/*",
      "tracks/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
